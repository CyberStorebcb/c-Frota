# Copie para .env e preencha (não versionar .env com segredos).

VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.5-flash

# Login administrador (papel "admin" + menu Administrador). Em produção use backend.
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=

# Utilizadores especiais: registo em /registro-especial (localStorage frota.users.special).

# Supabase — obtenha em: Project Settings > API
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# Evidências de checklist: textos/metadata no Supabase; ficheiros no R2 quando configurado.
# URL do Worker (ou outro presigner) que responde POST { "key", "contentType" } → { "uploadUrl", "publicUrl" }.
# Ver cloudflare/r2-presigner-worker/
VITE_R2_PRESIGN_URL=
# Opcional — enviado como Authorization: Bearer … no pedido ao presigner.
VITE_R2_PRESIGN_API_KEY=
